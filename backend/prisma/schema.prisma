generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  AGENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  NEGOTIATING
  CLOSED
  LOST
}

enum LeadSource {
  MANUAL
  WEBSITE
  PORTAL
  REFERRAL
  SOCIAL_MEDIA
  WHATSAPP
  API
  OTHER
}

enum IngestionStatus {
  RECEIVED
  PROCESSED
  FAILED
}

enum ReminderStatus {
  PENDING
  SENT
  COMPLETED
  CANCELLED
}

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
  LAND
  INDUSTRIAL
  OTHER
}

enum PropertyStatus {
  AVAILABLE
  SOLD
  RENTED
  OFF_MARKET
}

enum ClientType {
  BUYER
  SELLER
  BOTH
}

enum VisitStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum DealStage {
  INQUIRY
  NEGOTIATION
  AGREEMENT
  CLOSED
  LOST
}

enum DealStatus {
  OPEN
  WON
  LOST
  CANCELLED
}

enum DealDocumentType {
  CONTRACT
  AGREEMENT
  INVOICE
  KYC
  OTHER
}

enum ActivityType {
  CALL
  SMS
  EMAIL
  NOTE
  MEETING
  SITE_VISIT
  TASK
  STATUS_CHANGE
  SYSTEM
}

enum ActivityDirection {
  INBOUND
  OUTBOUND
  INTERNAL
}

enum NotificationType {
  EMAIL
  IN_APP
  SYSTEM
}

enum NotificationChannel {
  EMAIL
  IN_APP
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED
  READ
}

enum ReportType {
  SALES
  LEAD_CONVERSION
  AGENT_PERFORMANCE
  REVENUE
  CUSTOM
}

enum ExportFormat {
  PDF
  XLSX
  CSV
}

enum WebhookEventType {
  LEAD_CREATED
  LEAD_UPDATED
  DEAL_STAGE_CHANGED
  DEAL_CLOSED
  PROPERTY_CREATED
  PROPERTY_UPDATED
  NOTIFICATION_SENT
}

enum WebhookDeliveryStatus {
  PENDING
  SUCCESS
  FAILED
  RETRYING
  DISABLED
}

enum PipelineType {
  LEAD
  DEAL
}

model User {
  id                         String                 @id @default(cuid())
  firstName                  String
  lastName                   String
  email                      String                 @unique
  phone                      String?
  passwordHash               String
  role                       UserRole               @default(AGENT)
  status                     UserStatus             @default(ACTIVE)
  avatarUrl                  String?
  lastLoginAt                DateTime?
  managerId                  String?
  manager                    User?                  @relation("ManagerToAgents", fields: [managerId], references: [id], onDelete: SetNull)
  agents                     User[]                 @relation("ManagerToAgents")
  createdLeads               Lead[]                 @relation("LeadCreatedBy")
  assignedLeads              Lead[]                 @relation("LeadAssignedTo")
  leadAssignmentsAsAgent     LeadAssignment[]       @relation("LeadAssignedAgent")
  leadAssignmentsGiven       LeadAssignment[]       @relation("LeadAssignedBy")
  leadAssignmentRulesCreated LeadAssignmentRule[]   @relation("LeadRuleCreatedBy")
  leadAssignmentRulesAssigned LeadAssignmentRule[]  @relation("LeadRuleAssignedTo")
  remindersAssigned          FollowUpReminder[]     @relation("ReminderAssignedTo")
  remindersCreated           FollowUpReminder[]     @relation("ReminderCreatedBy")
  ownedProperties            Property[]             @relation("PropertyOwnerAgent")
  createdProperties          Property[]             @relation("PropertyCreatedBy")
  clientsOwned               Client[]               @relation("ClientOwnerAgent")
  dealsOwned                 Deal[]                 @relation("DealOwner")
  dealsCreated               Deal[]                 @relation("DealCreatedBy")
  activitiesCreated          Activity[]             @relation("ActivityCreatedBy")
  notificationsReceived      Notification[]         @relation("NotificationRecipient")
  reportExports              ReportExport[]         @relation("ReportGeneratedBy")
  refreshTokens              RefreshToken[]
  webhookEndpoints           WebhookEndpoint[]      @relation("WebhookCreatedBy")
  webhookDeliveries          WebhookDelivery[]      @relation("WebhookDeliveredBy")
  dealStageChanges           DealStageHistory[]     @relation("DealStageChangedBy")
  dealDocumentsUploaded      DealDocument[]         @relation("DealDocumentUploadedBy")
  propertyVisitsCreated      ClientPropertyVisit[]  @relation("VisitCreatedBy")
  apiCredentialsCreated      ApiCredential[]        @relation("ApiCredentialCreatedBy")
  createdAt                  DateTime               @default(now())
  updatedAt                  DateTime               @updatedAt
  deletedAt                  DateTime?

  @@index([role, status])
  @@index([managerId])
}

model RefreshToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  userAgent  String?
  ipAddress  String?
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model ApiCredential {
  id          String   @id @default(cuid())
  name        String
  keyHash     String   @unique
  scopes      Json?
  isActive    Boolean  @default(true)
  lastUsedAt  DateTime?
  createdById String
  createdBy   User     @relation("ApiCredentialCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([createdById])
}

model Lead {
  id               String            @id @default(cuid())
  firstName        String
  lastName         String?
  fullName         String?
  email            String?
  phone            String
  alternatePhone   String?
  budgetMin        Decimal?          @db.Decimal(15, 2)
  budgetMax        Decimal?          @db.Decimal(15, 2)
  preferredLocations Json?
  preferences      Json?
  source           LeadSource        @default(MANUAL)
  sourceDetails    String?
  status           LeadStatus        @default(NEW)
  score            Int               @default(0)
  notes            String?           @db.Text
  assignedToId     String?
  createdById      String
  lastContactedAt  DateTime?
  nextFollowUpAt   DateTime?
  isApiLead        Boolean           @default(false)
  externalRef      String?
  assignedTo       User?             @relation("LeadAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy        User              @relation("LeadCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  convertedClient  Client?           @relation("LeadToClient")
  assignments      LeadAssignment[]
  reminders        FollowUpReminder[]
  activities       Activity[]
  deals            Deal[]
  ingestionLogs    LeadIngestionLog[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([status, source])
  @@index([assignedToId])
  @@index([createdById])
  @@index([externalRef])
}

model LeadIngestionLog {
  id           String          @id @default(cuid())
  source       LeadSource
  payload      Json
  status       IngestionStatus @default(RECEIVED)
  errorMessage String?         @db.Text
  leadId       String?
  receivedAt   DateTime        @default(now())
  processedAt  DateTime?
  lead         Lead?           @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([status, receivedAt])
  @@index([leadId])
}

model LeadAssignmentRule {
  id            String           @id @default(cuid())
  name          String
  description   String?
  isActive      Boolean          @default(true)
  source        LeadSource?
  minBudget     Decimal?         @db.Decimal(15, 2)
  maxBudget     Decimal?         @db.Decimal(15, 2)
  preferredCity String?
  assignToId    String?
  createdById   String
  priority      Int              @default(100)
  assignTo      User?            @relation("LeadRuleAssignedTo", fields: [assignToId], references: [id], onDelete: SetNull)
  createdBy     User             @relation("LeadRuleCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  assignments   LeadAssignment[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([isActive, priority])
  @@index([assignToId])
  @@index([createdById])
}

model LeadAssignment {
  id           String              @id @default(cuid())
  leadId       String
  agentId      String
  assignedById String
  ruleId       String?
  reason       String?
  lead         Lead                @relation(fields: [leadId], references: [id], onDelete: Cascade)
  agent        User                @relation("LeadAssignedAgent", fields: [agentId], references: [id], onDelete: Restrict)
  assignedBy   User                @relation("LeadAssignedBy", fields: [assignedById], references: [id], onDelete: Restrict)
  rule         LeadAssignmentRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  createdAt    DateTime            @default(now())

  @@index([leadId, createdAt])
  @@index([agentId])
  @@index([assignedById])
  @@index([ruleId])
}

model FollowUpReminder {
  id           String         @id @default(cuid())
  leadId       String?
  clientId     String?
  dealId       String?
  assignedToId String
  createdById  String
  title        String
  description  String?
  dueAt        DateTime
  status       ReminderStatus @default(PENDING)
  completedAt  DateTime?
  lead         Lead?          @relation(fields: [leadId], references: [id], onDelete: SetNull)
  client       Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  deal         Deal?          @relation(fields: [dealId], references: [id], onDelete: SetNull)
  assignedTo   User           @relation("ReminderAssignedTo", fields: [assignedToId], references: [id], onDelete: Restrict)
  createdBy    User           @relation("ReminderCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([assignedToId, status, dueAt])
  @@index([createdById])
  @@index([leadId])
  @@index([clientId])
  @@index([dealId])
}

model Property {
  id            String               @id @default(cuid())
  title         String
  description   String?              @db.Text
  addressLine1  String
  addressLine2  String?
  city          String
  state         String
  country       String
  zipCode       String?
  latitude      Decimal?             @db.Decimal(10, 7)
  longitude     Decimal?             @db.Decimal(10, 7)
  type          PropertyType
  status        PropertyStatus       @default(AVAILABLE)
  listingPrice  Decimal              @db.Decimal(15, 2)
  sizeSqft      Decimal?             @db.Decimal(12, 2)
  bedrooms      Int?
  bathrooms     Decimal?             @db.Decimal(4, 1)
  parkingSpaces Int?
  yearBuilt     Int?
  amenities     Json?
  tags          Json?
  isFeatured    Boolean              @default(false)
  ownerAgentId  String?
  createdById   String
  ownerAgent    User?                @relation("PropertyOwnerAgent", fields: [ownerAgentId], references: [id], onDelete: SetNull)
  createdBy     User                 @relation("PropertyCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  images        PropertyImage[]
  visits        ClientPropertyVisit[]
  deals         Deal[]
  activities    Activity[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([type, status])
  @@index([city, state, country])
  @@index([listingPrice])
  @@index([ownerAgentId])
  @@index([createdById])
}

model PropertyImage {
  id         String   @id @default(cuid())
  propertyId String
  url        String
  publicId   String
  caption    String?
  isPrimary  Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, sortOrder])
}

model Client {
  id             String                @id @default(cuid())
  type           ClientType
  firstName      String
  lastName       String?
  companyName    String?
  email          String?
  phone          String
  alternatePhone String?
  budgetMin      Decimal?              @db.Decimal(15, 2)
  budgetMax      Decimal?              @db.Decimal(15, 2)
  preferences    Json?
  addressLine1   String?
  addressLine2   String?
  city           String?
  state          String?
  country        String?
  zipCode        String?
  notes          String?               @db.Text
  ownerAgentId   String?
  leadId         String?               @unique
  ownerAgent     User?                 @relation("ClientOwnerAgent", fields: [ownerAgentId], references: [id], onDelete: SetNull)
  lead           Lead?                 @relation("LeadToClient", fields: [leadId], references: [id], onDelete: SetNull)
  visits         ClientPropertyVisit[]
  activities     Activity[]
  deals          Deal[]                @relation("DealClient")
  reminders      FollowUpReminder[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([ownerAgentId, type])
  @@index([city, state, country])
}

model ClientPropertyVisit {
  id          String     @id @default(cuid())
  clientId    String
  propertyId  String
  visitAt     DateTime
  status      VisitStatus @default(SCHEDULED)
  feedback    String?    @db.Text
  rating      Int?
  createdById String
  client      Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  property    Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdBy   User       @relation("VisitCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([clientId, propertyId, visitAt])
  @@index([visitAt, status])
  @@index([createdById])
}

model Deal {
  id                String            @id @default(cuid())
  title             String
  description       String?           @db.Text
  stage             DealStage         @default(INQUIRY)
  status            DealStatus        @default(OPEN)
  expectedCloseDate DateTime?
  closeDate         DateTime?
  dealValue         Decimal           @db.Decimal(15, 2)
  commissionRate    Decimal?          @db.Decimal(5, 2)
  commissionAmount  Decimal?          @db.Decimal(15, 2)
  commissionPaid    Decimal           @default(0) @db.Decimal(15, 2)
  currency          String            @default("USD")
  clientId          String
  propertyId        String?
  leadId            String?
  ownerId           String
  createdById       String
  client            Client            @relation("DealClient", fields: [clientId], references: [id], onDelete: Restrict)
  property          Property?         @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  lead              Lead?             @relation(fields: [leadId], references: [id], onDelete: SetNull)
  owner             User              @relation("DealOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  createdBy         User              @relation("DealCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  documents         DealDocument[]
  stageHistory      DealStageHistory[]
  activities        Activity[]
  reminders         FollowUpReminder[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([stage, status])
  @@index([ownerId])
  @@index([createdById])
  @@index([clientId])
  @@index([leadId])
  @@index([propertyId])
}

model DealStageHistory {
  id          String    @id @default(cuid())
  dealId      String
  fromStage   DealStage?
  toStage     DealStage
  changedById String
  note        String?
  deal        Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  changedBy   User      @relation("DealStageChangedBy", fields: [changedById], references: [id], onDelete: Restrict)
  createdAt   DateTime  @default(now())

  @@index([dealId, createdAt])
  @@index([changedById])
}

model DealDocument {
  id           String           @id @default(cuid())
  dealId        String
  type          DealDocumentType @default(OTHER)
  fileName      String
  mimeType      String
  sizeBytes     Int
  url           String
  publicId      String?
  uploadedById  String
  notes         String?
  expiresAt     DateTime?
  deal          Deal             @relation(fields: [dealId], references: [id], onDelete: Cascade)
  uploadedBy    User             @relation("DealDocumentUploadedBy", fields: [uploadedById], references: [id], onDelete: Restrict)
  uploadedAt    DateTime         @default(now())

  @@index([dealId, type])
  @@index([uploadedById])
}

model Activity {
  id          String             @id @default(cuid())
  type        ActivityType
  direction   ActivityDirection  @default(INTERNAL)
  subject     String?
  description String?            @db.Text
  metadata    Json?
  performedAt DateTime           @default(now())
  createdById String
  leadId      String?
  clientId    String?
  dealId      String?
  propertyId  String?
  createdBy   User               @relation("ActivityCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  lead        Lead?              @relation(fields: [leadId], references: [id], onDelete: SetNull)
  client      Client?            @relation(fields: [clientId], references: [id], onDelete: SetNull)
  deal        Deal?              @relation(fields: [dealId], references: [id], onDelete: SetNull)
  property    Property?          @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([type, performedAt])
  @@index([createdById])
  @@index([leadId])
  @@index([clientId])
  @@index([dealId])
  @@index([propertyId])
}

model Notification {
  id           String             @id @default(cuid())
  recipientId  String
  type         NotificationType   @default(IN_APP)
  channel      NotificationChannel @default(IN_APP)
  status       NotificationStatus @default(QUEUED)
  title        String
  message      String             @db.Text
  entityType   String?
  entityId     String?
  sentAt       DateTime?
  readAt       DateTime?
  errorMessage String?            @db.Text
  metadata     Json?
  recipient    User               @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([recipientId, status, createdAt])
  @@index([entityType, entityId])
}

model ReportExport {
  id            String      @id @default(cuid())
  type          ReportType
  format        ExportFormat
  fileUrl       String?
  fileName      String?
  filters       Json?
  generatedById String
  generatedBy   User        @relation("ReportGeneratedBy", fields: [generatedById], references: [id], onDelete: Restrict)
  generatedAt   DateTime    @default(now())
  expiresAt     DateTime?

  @@index([generatedById, generatedAt])
}

model WebhookEndpoint {
  id              String            @id @default(cuid())
  name            String
  url             String
  secret          String
  isActive        Boolean           @default(true)
  events          Json
  createdById     String
  lastTriggeredAt DateTime?
  failureCount    Int               @default(0)
  createdBy       User              @relation("WebhookCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  deliveries      WebhookDelivery[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([isActive])
  @@index([createdById])
}

model WebhookDelivery {
  id           String                @id @default(cuid())
  endpointId   String
  eventType    WebhookEventType
  payload      Json
  status       WebhookDeliveryStatus @default(PENDING)
  responseCode Int?
  responseBody String?               @db.Text
  attemptCount Int                   @default(0)
  nextRetryAt  DateTime?
  deliveredById String?
  endpoint     WebhookEndpoint       @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  deliveredBy  User?                 @relation("WebhookDeliveredBy", fields: [deliveredById], references: [id], onDelete: SetNull)
  createdAt    DateTime              @default(now())
  deliveredAt  DateTime?

  @@index([endpointId, status])
  @@index([eventType, createdAt])
  @@index([nextRetryAt])
}

model PipelineStageSetting {
  id          String       @id @default(cuid())
  pipeline    PipelineType
  stageKey    String
  displayName String
  order       Int
  isDefault   Boolean      @default(false)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([pipeline, stageKey])
  @@unique([pipeline, order])
}
