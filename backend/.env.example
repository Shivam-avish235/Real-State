NODE_ENV=development
PORT=5000
APP_BASE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

DATABASE_URL=mysql://root:password@localhost:3306/real_estate_crm

JWT_ACCESS_SECRET=change_me_access_secret_1234567890
JWT_REFRESH_SECRET=change_me_refresh_secret_1234567890
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM="Real Estate CRM <noreply@example.com>"

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

WEBHOOK_RETRY_LIMIT=5
WEBHOOK_RETRY_DELAY_SEC=60
